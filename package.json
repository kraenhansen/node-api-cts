{
  "name": "node-api-cts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "type-check": "tsc --noEmit --project tools && tsc --noEmit --project tests && tsc --noEmit --project implementors/node",
    "lint": "eslint",
    "fetch-node-tests": "node ./tools/fetch-nodejs-tests-and-docs.ts main",
    "copy-node-files": "cp node/test/js-native-api/common.h node/test/js-native-api/common-inl.h tests/engine",
    "build-addons": "cmake-js build",
    "node:test": "node --test ./implementors/node/run-tests.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "cmake-js": "^7.4.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3"
  }
}
